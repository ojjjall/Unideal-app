{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "message",
        "order",
        "system",
        "verification"
      ]
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "sender_name": {
      "type": "string"
    },
    "link": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "message"
  ]
}