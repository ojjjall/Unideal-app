      }
    },
    "participant_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "product_id": {
      "type": "string"
    },
    "product_title": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_time": {
